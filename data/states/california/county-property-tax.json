    "notes": {
      "tax_rate_format": "California property tax is constrained by Proposition 13. Base rate is 1% of assessed value; voter-approved bonds and special assessments are additive. Assessed value increases capped at 2% annually.",
      "prop_13": {
        "base_rate_pct": 1.0,
        "annual_increase_cap_pct": 2,
        "reassessment_triggers": [
          "Change of ownership",
          "New construction"
        ],
        "homeowner_exemption_assessed_value": 7000
      },
      "disabled_veteran_exemption_statewide": {
        "basic_assessed_value_reduction": 180671,
        "low_income_assessed_value_reduction": 271009,
        "low_income_household_limit": 81131,
        "year": 2026,
        "inflation_indexed": true,
        "eligibility": "100% service-connected disability or IU at 100%, or blind in both eyes, or loss of use of two or more limbs",
        "basic_filing": "One-time filing with county assessor",
        "low_income_filing": "Annual filing by February 15",
        "form": "BOE-261-G",
        "source": "https://www.boe.ca.gov/proptaxes/dv_exemption.htm"
      },
      "scope": "Counties with major military installations and federal employment centers.",
      "update_cycle": "Tax rates set annually by county; Prop 13 base is fixed statewide."
    }
  },
