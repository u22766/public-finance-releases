{
  "metadata": {
    "title": "SSA Actuarial Period Life Table",
    "description": "Period life table for the Social Security area population. Provides death probabilities, survivor counts, and life expectancy by exact age and sex. Used for retirement planning horizon modeling.",
    "version": "1.0",
    "last_updated": "2026-03-11",
    "data_year": 2022,
    "trustees_report": "2025",
    "source": "https://www.ssa.gov/oact/STATS/table4c6.html",
    "methodology": "https://www.ssa.gov/oact/NOTES/as120/LifeTables_Body.html",
    "notes": {
      "period_table": "A period life table represents mortality experience within a given year. Life expectancy at a given age is the average remaining years using that year's mortality rates for all future ages.",
      "population": "Social Security area population: residents of 50 states + DC, civilian residents of US territories, federal employees abroad, non-citizens abroad insured for SS benefits, all other US citizens abroad.",
      "death_probability": "Probability of dying within one year at the exact age.",
      "number_of_lives": "Number of survivors out of 100,000 born alive.",
      "life_expectancy": "Average remaining years expected prior to death at that exact age.",
      "update_cycle": "SSA publishes updated tables with each annual Trustees Report, typically in March/April. The data year lags the report year by approximately 3 years."
    }
  },
