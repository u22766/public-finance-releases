{
  "metadata": {
    "name": "Capital Gains Tax Rates History",
    "description": "Historical long-term capital gains and qualified dividend tax rates by income bracket. Essential for investment liquidation planning in retirement.",
    "version": "1.2",
    "last_updated": "2026-03-16",
    "sources": [
      "https://taxfoundation.org/data/all/federal/federal-capital-gains-tax-collections-historical-data/",
      "IRS Revenue Procedures (annual inflation adjustments)",
      "Congressional Research Service: Capital Gains Taxes (RL31364)"
    ],
    "notes": [
      "Long-term capital gains (LTCG) = assets held >1 year. Short-term gains taxed as ordinary income.",
      "Qualified dividends taxed at same preferential rates as LTCG since 2003 (JGTRRA).",
      "Net Investment Income Tax (NIIT) of 3.8% applies above $200K single / $250K MFJ since 2013 (ACA).",
      "0% rate is critical for retirement planning: retirees in lower brackets can harvest gains tax-free.",
      "Bracket thresholds shown are for taxable income (after deductions)."
    ],
    "corrections": [
      {
        "date": "2026-03-16",
        "description": "Fixed 2026 capital gains thresholds: all values updated to IRS Rev. Proc. 2025-32 Section 4.03. Added HoH and MFS thresholds (previously missing). Prior values appeared to be pre-OBBBA projections.",
        "source": "IRS Rev. Proc. 2025-32, Section 4.03"
      },
      {
        "date": "2026-03-16",
        "description": "Fixed 2026 capital gains thresholds per Rev. Proc. 2025-32: Single 15% 50600->49450, 20% 558600->545500; MFJ 15% 101200->98900, 20% 628300->613700. Added HoH and MFS thresholds."
      }
    ],
    "cross_references": [
      {
        "file": "federal/filing-status-thresholds.json",
        "manifest_key": "filing_status_thresholds",
        "note": "Contains all 5 filing statuses with brackets, standard deductions, and other thresholds co-located. Use for tax computation; use this file for capital gains rate history."
      }
    ]
  },
