{
  "metadata": {
    "name": "Federal Income Tax Brackets",
    "description": "Historical federal marginal income tax brackets by filing status. Covers the modern bracket era from 2001 (EGTRRA) through 2026.",
    "version": "1.2",
    "last_updated": "2026-03-16",
    "sources": [
      "https://www.irs.gov/newsroom/irs-provides-tax-inflation-adjustments-for-tax-year-2026",
      "https://taxfoundation.org/data/all/federal/historical-income-tax-rates-brackets/",
      "IRS Revenue Procedures (annual inflation adjustments)"
    ],
    "notes": [
      "Brackets shown are for ordinary income (wages, pensions, IRA distributions, SS above thresholds).",
      "2001-2002: Pre-EGTRRA rates (15%, 28%, 31%, 36%, 39.6%) plus new 10% bracket in 2001.",
      "2003-2012: EGTRRA/JGTRRA rates (10%, 15%, 25%, 28%, 33%, 35%).",
      "2013-2017: ATRA restored 39.6% top rate, added ACA 0.9% Medicare surtax.",
      "2018-2025: TCJA rates (10%, 12%, 22%, 24%, 32%, 35%, 37%).",
      "2026: TCJA rates made permanent by OBBBA. Brackets per IRS Rev. Proc. 2025-32.",
      "All bracket thresholds are the START of each bracket (income at or above).",
      "Retirement planning use: Roth conversion analysis, tax-efficient withdrawal sequencing, IRMAA bracket awareness."
    ],
    "source": [
      "IRS Revenue Procedures (annual inflation adjustments) \u2014 primary source for all bracket thresholds",
      "https://www.irs.gov/newsroom/inflation-adjusted-tax-items-by-tax-year",
      "https://taxfoundation.org/data/all/federal/historical-income-tax-rates-brackets/"
    ],
    "source_verification": {
      "verified_date": "2026-03-12",
      "method": "Spot-checked 12 of 26 years against IRS Revenue Procedures (Rev. Proc. 2001-13 through Rev. Proc. 2025-32)",
      "years_verified": [
        2001,
        2003,
        2005,
        2007,
        2010,
        2013,
        2015,
        2017,
        2018,
        2020,
        2022,
        2024
      ],
      "checks_passed": 218,
      "result": "All bracket thresholds, rates, and filing status values match IRS primary sources exactly"
    },
    "cross_references": [
      {
        "file": "federal/filing-status-thresholds.json",
        "manifest_key": "filing_status_thresholds",
        "note": "For tax computation requiring all 5 filing statuses (Single, MFJ, MFS, HoH, QSS) with co-located standard deductions, age 65+ additional deductions, and OBBBA senior deduction, use filing-status-thresholds. This file provides historical bracket evolution (2001-2026) for Single and MFJ only \u2014 suited for Roth conversion modeling and bracket trend analysis, not household-specific tax computation."
      }
    ]
  },
