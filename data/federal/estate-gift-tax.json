  "metadata": {
    "name": "Estate and Gift Tax Exemption History",
    "description": "Historical federal estate tax exemption amounts, top rates, gift tax annual exclusion, and generation-skipping transfer tax exemption. Essential for estate planning in retirement.",
    "version": "1.0.1",
    "last_updated": "2026-03-12",
    "sources": [
      "https://taxfoundation.org/data/all/federal/federal-estate-and-gift-tax-rates-exemptions-and-exclusions-1916-2014/",
      "IRS Revenue Procedures (annual inflation adjustments)",
      "Congressional Research Service: Federal Estate and Gift Taxes (R43089)"
    ],
    "notes": [
      "Estate tax exemption = amount that can pass to heirs tax-free. Portable between spouses since 2011.",
      "Gift tax annual exclusion = amount per recipient per year with no tax or reporting required.",
      "Lifetime gift tax exemption is unified with estate tax exemption.",
      "TCJA (2018-2025) doubled the exemption. Scheduled to sunset in 2026 but may be extended.",
      "For retirement planning: estate tax interacts with inherited IRA rules, Roth conversion strategy, and beneficiary planning."
    ]
  },
