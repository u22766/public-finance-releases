{
  "metadata": {
    "name": "Social Security PIA Bend Points",
    "description": "Dollar amounts in Primary Insurance Amount (PIA) formula used to calculate Social Security benefits. Called 'bend points' because the formula graph bends at these amounts.",
    "version": "1.0",
    "last_updated": "2026-03-08",
    "source": "https://www.ssa.gov/oact/cola/bendpoints.html",
    "notes": [
      "PIA formula: 90% of AIME up to 1st bend point + 32% between 1st and 2nd + 15% above 2nd",
      "Bend points indexed to national average wage with 2-year lag",
      "Year shown is year of eligibility (attaining age 62, disability, or death before 62)",
      "Base year 1979: $180 and $1,085 (set by 1977 amendments)"
    ]
  },
